---
import Layout from '../layouts/Layout.astro'
import TreeIcon from '../components/TreeIcon.tsx'
import '../index.css'
---

<Layout title="PhyloGuessr">
  <div class="game">
    <header class="game-header">
      <div class="header-left">
        <TreeIcon />
        <h1>
          <a class="home-btn" href={import.meta.env.BASE_URL}>PhyloGuessr</a>
        </h1>
      </div>
      <div class="header-animals" aria-hidden="true">
        <img class="header-animal animal-platypus" src="https://images.phylopic.org/images/61932f57-1fd2-49d9-bb86-042d6005581a/thumbnail/128x128.png" alt="" />
        <img class="header-animal animal-aardvark" src="https://images.phylopic.org/images/cfee2dca-3767-46b8-8d03-bd8f46e79e9e/thumbnail/128x128.png" alt="" />
        <img class="header-animal animal-octopus" src="https://images.phylopic.org/images/f400b519-3564-4183-b4bd-c3b922cc7c5e/thumbnail/128x128.png" alt="" />
        <img class="header-animal animal-hippo" src="https://images.phylopic.org/images/3769e205-b10c-4aab-affc-b4f0302f4eaa/thumbnail/128x128.png" alt="" />
        <img class="header-animal animal-axolotl" src="https://images.phylopic.org/images/575eaa51-6c9b-4d36-9881-b8463c68ebbc/thumbnail/128x128.png" alt="" />
        <img class="header-animal animal-horseshoecrab" src="https://images.phylopic.org/images/38c82deb-b187-4e85-a9f8-dba2794b42d0/thumbnail/128x128.png" alt="" />
      </div>
      <div class="header-right">
        <a href={`${import.meta.env.BASE_URL}about`} class="about-btn" title="About">?</a>
      </div>
    </header>
    <div class="start-screen">
      <h3 class="wordart-subtitle">
        The game where you try to guess which two organisms are most closely
        related
      </h3>
      <div class="mode-selector">
        <a class="mode-btn mode-btn-easy" href={`${import.meta.env.BASE_URL}easy`}>Easy <span class="btn-emoji">🍿</span></a>
        <a class="mode-btn mode-btn-random" href={`${import.meta.env.BASE_URL}random`}>Random <span class="btn-emoji">🎰</span></a>
        <a class="mode-btn mode-btn-custom" href={`${import.meta.env.BASE_URL}custom`}>Custom <span class="btn-emoji">📠</span></a>
      </div>
    </div>
  </div>
</Layout>
