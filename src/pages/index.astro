---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.tsx'
import '../index.css'
---

<Layout title="PhyloGuessr">
  <div class="game">
    <Header client:load />
    <div class="start-screen">
      <h3 class="wordart-subtitle">
        The evolutionary guessing game
      </h3>
      <div class="difficulty-selector">
        <button class="diff-btn" data-difficulty="normal">Show species labels</button>
        <button class="diff-btn" data-difficulty="nolabels">Don't show species labels</button>
      </div>
      <div class="mode-selector">
        <a class="mode-btn mode-btn-easy" href="/easy">Easy <span class="btn-emoji">🍿</span></a>
        <a class="mode-btn mode-btn-random" href="/random">Random <span class="btn-emoji">🎰</span></a>
        <a class="mode-btn mode-btn-custom" href="/custom">Custom <span class="btn-emoji">📠</span></a>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const diffBtns = document.querySelectorAll('.diff-btn')

  const saved = localStorage.getItem('phyloDifficulty')
  const active = (saved === 'nolabels' || saved === 'hard' || saved === 'expert') ? 'nolabels' : 'normal'
  diffBtns.forEach(btn => {
    btn.classList.toggle('active', btn.dataset.difficulty === active)
  })

  diffBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      diffBtns.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')
      const difficulty = btn.dataset.difficulty ?? 'normal'
      if (difficulty === 'normal') {
        localStorage.removeItem('phyloDifficulty')
      } else {
        localStorage.setItem('phyloDifficulty', difficulty)
      }
    })
  })
</script>

<style>
  .difficulty-selector {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-bottom: 16px;
  }

  .diff-btn {
    padding: 6px 18px;
    border-radius: 20px;
    border: 2px solid var(--color-primary, #2e7d32);
    background: transparent;
    color: var(--color-primary, #2e7d32);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    transition: background 0.15s, color 0.15s;
  }

  .diff-btn.active {
    background: var(--color-primary, #2e7d32);
    color: white;
  }
</style>
