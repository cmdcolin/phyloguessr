{
  "name": "compy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "clean": "rm -rf dist",
    "prebuild": "yarn clean",
    "build": "astro build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "astro preview",
    "predeploy": "yarn build",
    "deploy": "gh-pages -d dist  -t --nojekyll",
    "postdeploy": "git push --follow-tags",
    "build-taxonomy": "node scripts/build-taxonomy.mjs",
    "update-data": "node scripts/update-all.mjs",
    "test": "vitest run",
    "deploy:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "@types/leaflet": "^1.9.21",
    "astro": "^5.18.0",
    "d3-hierarchy": "^3.1.2",
    "firebase": "^12.10.0",
    "leaflet": "^1.9.4",
    "preact": "^10.28.4"
  },
  "devDependencies": {
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase-tools": "^15.9.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
