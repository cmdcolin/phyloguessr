rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /scores/{uid} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 20
                    && request.resource.data.totalPlayed == 1
                    && request.resource.data.totalWins <= 1
                    && request.resource.data.currentStreak <= 1
                    && request.resource.data.bestStreak <= 1;
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 20
                    && request.resource.data.totalPlayed == resource.data.totalPlayed + 1
                    && request.resource.data.totalWins >= resource.data.totalWins
                    && request.resource.data.totalWins <= resource.data.totalWins + 1
                    && (request.resource.data.currentStreak == 0
                        || request.resource.data.currentStreak == resource.data.currentStreak + 1)
                    && request.resource.data.bestStreak >= resource.data.bestStreak
                    && request.resource.data.bestStreak <= resource.data.bestStreak + 1;
      allow delete: if request.auth != null
                    && request.auth.uid == uid;
    }
    match /multiScores/{uid} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 20
                    && request.resource.data.totalPlayed == 1;
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 20
                    && request.resource.data.totalPlayed == resource.data.totalPlayed + 1
                    && request.resource.data.totalPoints >= resource.data.totalPoints
                    && request.resource.data.perfects >= resource.data.perfects;
      allow delete: if request.auth != null
                    && request.auth.uid == uid;
    }
    match /presence/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
                            && request.auth.uid == uid;
      allow delete: if request.auth != null
                    && request.auth.uid == uid;
    }
  }
}
